<Objects>
  <!-- Ordinary Client — ROTF Runes (Phase D2). These are the equipped runes held in
       Player.Runes (the 4 rune slots), NOT inventory items; BoostStatManager.ApplyRuneBonus
       applies their <ActivateOnEquip> stat boosts. Server-side only (client never renders them).
       Slot themes recovered from the ROTF dev blog: Arcane(blue)/Chrysalis(green)/Impact(orange)/Adaptive(clear).
       Materials to obtain them (future blessing/crafting flow): Arcane/Chrysalis/Impact/Adaptive Symbols + Nodestones. -->
  <Object type="0x8ff0" id="Arcane Rune">
    <Class>Equipment</Class>
    <Item/>
    <Texture><File>lofiObj6</File><Index>0x10</Index></Texture>
    <SlotType>20</SlotType>
    <Description>Arcane rune (blue slot) - channels magical might.</Description>
    <ActivateOnEquip stat="27" amount="8">IncrementStat</ActivateOnEquip>
    <ActivateOnEquip stat="3" amount="40">IncrementStat</ActivateOnEquip>
    <BagType>0</BagType>
  </Object>

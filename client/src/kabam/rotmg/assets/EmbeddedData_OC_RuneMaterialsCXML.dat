<Objects>
  <!-- Ordinary Client - ROTF rune MATERIALS (Phase D2), matching the recovered Auction-House catalog.
       SYMBOLS (consumed x10 via /bless to grant the matching rune) + NODESTONES (Small/Big x normal/Starforce,
       the skill-tree material). Plain inventory items (placeholder gem sprites). Type ids 0x8fc0-0x8fc7. -->
  <Object type="0x8fc0" id="Arcane Symbol">
    <Class>Equipment</Class><Item/>
    <Texture><File>lofiObj6</File><Index>0x11</Index></Texture>
    <SlotType>20</SlotType>
    <Description>Arcane Symbol (blue). Consume 10 to bless the Arcane rune slot.</Description>
  </Object>
  <Object type="0x8fc1" id="Chrysalis Symbol">
